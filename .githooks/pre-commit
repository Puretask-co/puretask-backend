#!/usr/bin/env bash
set -e

# Block new markdown files unless they're in docs/active, docs/archive, or .githooks
NEW_MD=$(git diff --cached --name-only --diff-filter=A | grep -E '\.md$' || true)

if [ -n "$NEW_MD" ]; then
  BAD=$(echo "$NEW_MD" | grep -vE '^(docs/active/|docs/archive/|\.githooks/)' || true)
  if [ -n "$BAD" ]; then
    echo "❌ New markdown files must be created ONLY under:"
    echo "   - docs/active/"
    echo "   - docs/archive/"
    echo "   - .githooks/"
    echo ""
    echo "Blocked files:"
    echo "$BAD"
    echo ""
    echo "Fix: move them into docs/active/, docs/archive/, or .githooks/ and re-stage."
    exit 1
  fi
fi

exit 0
