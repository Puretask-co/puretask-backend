#!/usr/bin/env bash
set -e

# Block new markdown files unless they're in allowed doc paths or .githooks
NEW_MD=$(git diff --cached --name-only --diff-filter=A | grep -E '\.md$' || true)

if [ -n "$NEW_MD" ]; then
  BAD=$(echo "$NEW_MD" | grep -vE '^(docs/active/|docs/archive/|docs/_archive/|docs/runbooks/|docs/_md_inventory/|\.githooks/)' || true)
  if [ -n "$BAD" ]; then
    echo "❌ New markdown files must be created ONLY under:"
    echo "   - docs/active/"
    echo "   - docs/archive/"
    echo "   - docs/_archive/"
    echo "   - docs/runbooks/"
    echo "   - docs/_md_inventory/"
    echo "   - .githooks/"
    echo ""
    echo "Blocked files:"
    echo "$BAD"
    echo ""
    echo "Fix: move them into an allowed path above and re-stage."
    exit 1
  fi
fi

exit 0
