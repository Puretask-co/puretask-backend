# ============================================
# PureTask Backend - Canonical .gitignore
# ============================================
# This is the single source of truth for ignored files.
# If a file should never ship, it should never be tracked.

# ============================================
# Environment Variables (CRITICAL - Never commit secrets)
# ============================================
.env
.env.*
!.env.example
!.env.test.example
.env.local
.env.development.local
.env.test.local
.env.production.local

# Test environment files
test.env
*.test.env

# ============================================
# Dependencies
# ============================================
node_modules/
.pnp
.pnp.js
.yarn/
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# ============================================
# Build Artifacts
# ============================================
dist/
build/
out/
.next/
.turbo/
.cache/
*.tsbuildinfo

# ============================================
# Testing & Coverage
# ============================================
coverage/
.nyc_output/
test-results/
playwright-report/
*.lcov
.jest-cache/

# ============================================
# Logs
# ============================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
logs/
*.log.*

# ============================================
# IDE / Editor Files
# ============================================
.vs/
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# ============================================
# OS Files
# ============================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ============================================
# Deployment / Infrastructure
# ============================================
.railway/
.vercel/
.netlify/
.serverless/
.fusebox/
.dynamodb/
.tern-port
.terraform/
*.tfstate
*.tfstate.*

# ============================================
# Temporary Files
# ============================================
tmp/
temp/
*.tmp
*.temp
.cache/
.tmp/

# ============================================
# Package Manager Locks (keep package-lock.json, ignore others)
# ============================================
yarn.lock
pnpm-lock.yaml

# ============================================
# Database
# ============================================
*.sqlite
*.sqlite3

# Schema dumps (db:dump:schema)
prod.sql
test.sql
test_to_production_dump.sql
*.db
*.db-journal

# ============================================
# Secrets & Credentials (Extra Safety)
# ============================================
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx
secrets/
credentials/
*.secret
*.token
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub

# ============================================
# Misc
# ============================================
*.pid
*.seed
*.pid.lock
.npm
.eslintcache
.stylelintcache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/
