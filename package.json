{
  "name": "puretask-backend",
  "version": "1.0.0",
  "description": "PureTask Backend API - Uber-style cleaning marketplace",
  "private": true,
  "main": "dist/index.js",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint . --ext .ts --ignore-pattern \"scripts/**\"",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "test:security": "jest --testPathPattern=security",
    "test:coverage": "jest --config jest.config.coverage.js",
    "test:coverage:html": "jest --config jest.config.coverage.js && open coverage/index.html",
    "test:coverage:report": "jest --config jest.config.coverage.js --coverageReporters=text-summary",
    "analyze:bundle": "node scripts/analyze-bundle.js",
    "security:scan": "node scripts/secret-scan.js",
    "security:setup-hooks": "powershell -ExecutionPolicy Bypass -File scripts/setup-pre-commit.ps1",
    "worker:auto-cancel": "ts-node src/workers/autoCancelJobs.ts",
    "worker:auto-expire": "ts-node src/workers/autoExpireAwaitingApproval.ts",
    "worker:payout-weekly": "ts-node src/workers/payoutWeekly.ts",
    "worker:kpi-daily": "ts-node src/workers/kpiDailySnapshot.ts",
    "worker:backup-daily": "ts-node src/workers/backupDaily.ts",
    "worker:retry-notifications": "ts-node src/workers/retryFailedNotifications.ts",
    "worker:reliability-recalc": "ts-node src/workers/reliabilityRecalc.ts",
    "worker:webhook-retry": "ts-node src/workers/webhookRetry.ts",
    "worker:credit-economy": "ts-node src/workers/creditEconomyMaintenance.ts",
    "worker:stuck-detection": "ts-node src/workers/stuckJobDetection.ts",
    "worker:weekly-summary": "ts-node src/workers/weeklySummary.ts",
    "worker:onboarding-reminders": "ts-node src/workers/onboardingReminderWorker.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.9.0",
    "@sendgrid/mail": "^8.1.6",
    "@types/multer": "^2.0.0",
    "@types/passport": "^1.0.17",
    "@types/passport-facebook": "^3.0.4",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/qrcode": "^1.5.6",
    "@types/redis": "^4.0.10",
    "@types/speakeasy": "^2.0.10",
    "@types/ua-parser-js": "^0.7.39",
    "@types/uuid": "^10.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "openai": "^4.104.0",
    "passport": "^0.7.0",
    "passport-facebook": "^3.0.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.11.0",
    "qrcode": "^1.5.4",
    "redis": "^5.10.0",
    "speakeasy": "^2.0.0",
    "stripe": "^16.0.0",
    "twilio": "^5.0.0",
    "ua-parser-js": "^2.0.7",
    "uuid": "^13.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.2.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.11.0",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^4.0.16",
    "bcryptjs": "^3.0.3",
    "eslint": "^8.57.0",
    "jest": "^30.2.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  },
  "keywords": [
    "puretask",
    "cleaning",
    "marketplace",
    "api",
    "express",
    "typescript",
    "stripe"
  ]
}
