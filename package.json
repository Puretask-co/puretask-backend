{
  "name": "puretask-backend",
  "version": "1.0.0",
  "description": "PureTask Backend API - Uber-style cleaning marketplace",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint . --ext .ts --ignore-pattern \"scripts/**\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "vitest run src/tests/smoke",
    "test:integration": "vitest run src/tests/integration",
    "test:v1-hardening": "vitest run src/tests/integration/v1Hardening.test.ts",
    "test:coverage": "vitest run --coverage",
    "test:worker-dryrun": "ts-node scripts/test-worker-dryrun.ts",
    "test:stripe-e2e": "ts-node scripts/test-stripe-e2e.ts",
    "test:v1-features": "ts-node scripts/test-v1-features.ts",
    "test:v3-endpoints": "ts-node scripts/test-v3-endpoints.ts",
    "verify:v3": "node scripts/verify-v3-deployment.js",
    "test:v4-endpoints": "ts-node scripts/test-v4-endpoints.ts",
    "verify:v4": "node scripts/verify-v4-deployment.js",
    "worker:auto-cancel": "ts-node src/workers/autoCancelJobs.ts",
    "worker:auto-expire": "ts-node src/workers/autoExpireAwaitingApproval.ts",
    "worker:payout-weekly": "ts-node src/workers/payoutWeekly.ts",
    "worker:kpi-daily": "ts-node src/workers/kpiDailySnapshot.ts",
    "worker:backup-daily": "ts-node src/workers/backupDaily.ts",
    "worker:retry-notifications": "ts-node src/workers/retryFailedNotifications.ts",
    "worker:reliability-recalc": "ts-node src/workers/reliabilityRecalc.ts",
    "worker:webhook-retry": "ts-node src/workers/webhookRetry.ts",
    "worker:credit-economy": "ts-node src/workers/creditEconomyMaintenance.ts",
    "worker:stuck-detection": "ts-node src/workers/stuckJobDetection.ts",
    "worker:weekly-summary": "ts-node src/workers/weeklySummary.ts",
    "worker:payout-retry": "ts-node src/workers/payoutRetry.ts",
    "worker:subscription-jobs": "ts-node src/workers/subscriptionJobs.ts",
    "worker:expire-boosts": "ts-node src/workers/expireBoosts.ts",
    "worker:queue-processor": "ts-node src/workers/queueProcessor.ts",
    "worker:cleaning-scores": "ts-node src/workers/cleaningScores.ts",
    "worker:goal-checker": "ts-node src/workers/goalChecker.ts",
    "migrate:run": "node scripts/run-migration.js",
    "migrate:fix-payouts-fk": "node scripts/run-migration.js DB/migrations/000_fix_payouts_fk.sql",
    "migrate:verify": "node scripts/verify-migration.js",
    "db:seed": "ts-node src/db/seed.ts",
    "deploy:staging": "bash scripts/deploy-staging.sh",
    "deploy:production": "bash scripts/deploy-production.sh",
    "setup:staging": "bash scripts/setup-staging.sh"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.9.0",
    "@sendgrid/mail": "^8.1.0",
    "@types/helmet": "^0.0.48",
    "@vercel/speed-insights": "^1.3.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.0",
    "stripe": "^16.0.0",
    "twilio": "^5.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.11.0",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^8.57.0",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "puretask",
    "cleaning",
    "marketplace",
    "api",
    "express",
    "typescript",
    "stripe"
  ],
  "license": "UNLICENSED"
}
