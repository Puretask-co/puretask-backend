{
  "name": "puretask-backend",
  "version": "1.1.0",
  "description": "PureTask Backend API - Uber-style cleaning marketplace",
  "private": true,
  "main": "dist/index.js",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "dev:all": "powershell -ExecutionPolicy Bypass -File scripts/dev-all.ps1",
    "dev:stop": "powershell -ExecutionPolicy Bypass -File scripts/dev-stop.ps1",
    "build": "tsc -p tsconfig.json",
    "start": "node -r ./dist/instrument.js ./dist/index.js",
    "lint": "eslint . --ext .ts --ignore-pattern \"scripts/**\"",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "vitest run src/tests/smoke",
    "test:integration": "vitest run src/tests/integration",
    "test:coverage": "vitest run --coverage",
    "analyze:bundle": "node scripts/analyze-bundle.js",
    "security:scan": "node scripts/secret-scan.js",
    "backup:verify": "ts-node scripts/verify-backup.ts",
    "docs:postman": "ts-node scripts/generate-postman-collection.ts",
    "monitoring:verify": "ts-node scripts/verify-monitoring.ts",
    "test:load": "k6 run tests/load/api-load-test.js",
    "test:load:jobs": "k6 run tests/load/job-lifecycle-test.js",
    "test:performance": "ts-node tests/performance/benchmarks.ts",
    "db:migrate": "node scripts/run-migration.js DB/migrations/000_COMPLETE_CONSOLIDATED_SCHEMA.sql",
    "db:setup:test": "node scripts/setup-test-db.js",
    "db:reset:test": "node scripts/reset-test-db.js",
    "db:patch:production": "node scripts/run-production-schema-patch.js",
    "db:verify:production": "node scripts/verify-production-schema.js",
    "db:validate:migrations": "node scripts/validate-migrations.js",
    "db:generate:neon-uuid": "node scripts/generate-neon-uuid-bundle.js --output DB/neon/gamification_uuid.sql",
    "security:setup-hooks": "powershell -ExecutionPolicy Bypass -File scripts/setup-pre-commit.ps1",
    "worker:auto-cancel": "ts-node src/workers/v1-core/autoCancelJobs.ts",
    "worker:auto-expire": "ts-node src/workers/v1-core/autoExpireAwaitingApproval.ts",
    "worker:payout-weekly": "ts-node src/workers/v1-core/payoutWeekly.ts",
    "worker:kpi-daily": "ts-node src/workers/v4-analytics/kpiDailySnapshot.ts",
    "worker:backup-daily": "ts-node src/workers/v2-operations/backupDaily.ts",
    "worker:retry-notifications": "ts-node src/workers/v1-core/retryFailedNotifications.ts",
    "worker:reliability-recalc": "ts-node src/workers/reliability/reliabilityRecalc.ts",
    "worker:webhook-retry": "ts-node src/workers/v1-core/webhookRetry.ts",
    "worker:credit-economy": "ts-node src/workers/v2-operations/creditEconomyMaintenance.ts",
    "worker:weekly-summary": "ts-node src/workers/v4-analytics/weeklySummary.ts",
    "worker:onboarding-reminders": "ts-node src/workers/onboardingReminderWorker.ts",
    "worker:lock-recovery": "ts-node src/workers/lockRecovery.ts",
    "worker:scheduler": "ts-node src/workers/scheduler.ts",
    "worker:durable-jobs": "ts-node src/workers/runDurableJobWorker.ts",
    "worker:durable-jobs:loop": "ts-node src/workers/runDurableJobWorker.ts --loop",
    "worker:governor-metrics": "ts-node src/workers/gamification/computeGovernorMetrics.ts",
    "worker:cleaning-scores": "ts-node src/workers/reliability/cleaningScores.ts",
    "worker:goal-checker": "ts-node src/workers/v2-operations/goalChecker.ts",
    "seed:gamification": "ts-node scripts/seed_gamification_config.ts",
    "seed:gamification:dry-run": "ts-node scripts/seed_gamification_config.ts --dry-run"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.9.0",
    "@sendgrid/mail": "^8.1.6",
    "@sentry/node": "^10.37.0",
    "@sentry/profiling-node": "^10.37.0",
    "@types/multer": "^2.0.0",
    "@types/passport": "^1.0.17",
    "@types/passport-facebook": "^3.0.4",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/qrcode": "^1.5.6",
    "@types/redis": "^4.0.10",
    "@types/speakeasy": "^2.0.10",
    "@types/ua-parser-js": "^0.7.39",
    "@types/uuid": "^10.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "openai": "^4.104.0",
    "passport": "^0.7.0",
    "passport-facebook": "^3.0.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.11.0",
    "qrcode": "^1.5.4",
    "redis": "^5.10.0",
    "speakeasy": "^2.0.0",
    "stripe": "^16.0.0",
    "twilio": "^5.0.0",
    "ua-parser-js": "^2.0.7",
    "uuid": "^13.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.2.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/k6": "^1.5.0",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.11.0",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "bcryptjs": "^3.0.3",
    "eslint": "^8.57.0",
    "jest": "^30.2.0",
    "k6": "^0.0.0",
    "prettier": "^3.2.5",
    "supertest": "^7.2.2",
    "vitest": "^2.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "puretask",
    "cleaning",
    "marketplace",
    "api",
    "express",
    "typescript",
    "stripe"
  ]
}
