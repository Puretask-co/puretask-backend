# ============================================
# PURETASK BACKEND - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# ============================================
# ðŸ” REQUIRED: Core Security & Database
# ============================================

# PostgreSQL Database Connection
# Format: postgres://user:pass@host:5432/dbname?sslmode=require
DATABASE_URL=postgres://user:pass@host:5432/dbname

# JWT Authentication Secret (CRITICAL!)
# PRODUCTION: Use a cryptographically secure 128+ character secret
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# This is your production-ready secret (256-bit entropy):
JWT_SECRET=c2f5bd0adc095f8c4571124e69c23177baa22aedfc8486c185e38279e09c7c9d2654d3d979a09a5beea07766bd56bb32a35f4c20ced90e9e069bfca9bba068c8

# JWT token expiration (e.g., "30d", "7d", "24h")
JWT_EXPIRES_IN=30d

# Password hashing rounds (10-12 recommended, higher = more secure but slower)
BCRYPT_SALT_ROUNDS=10

# Stripe Payment Processing
# Test mode: sk_test_... | Live mode: sk_live_...
STRIPE_SECRET_KEY=sk_test_replace
STRIPE_WEBHOOK_SECRET=whsec_replace

# n8n Webhook HMAC Secret (for webhook signature verification)
# Generate with same command as JWT_SECRET
N8N_WEBHOOK_SECRET=replace-with-n8n-hmac-secret

# ============================================
# ðŸš€ Runtime Configuration
# ============================================

NODE_ENV=development
PORT=4000

# ============================================
# ðŸ”§ Feature Flags & Kill Switches
# ============================================

# Production guard flags (set to "false" to disable)
BOOKINGS_ENABLED=true
PAYOUTS_ENABLED=false
CREDITS_ENABLED=true
REFUNDS_ENABLED=true
WORKERS_ENABLED=true

# ============================================
# ðŸ’° Business Rules
# ============================================

# Platform fee (percentage)
PLATFORM_FEE_PERCENT=15

# Cleaner payout percentages by tier
CLEANER_PAYOUT_PERCENT_BRONZE=80
CLEANER_PAYOUT_PERCENT_SILVER=82
CLEANER_PAYOUT_PERCENT_GOLD=84
CLEANER_PAYOUT_PERCENT_PLATINUM=85

# Credit system (10 credits =  USD)
CENTS_PER_CREDIT=10

# ============================================
# ðŸ“§ Notifications - SendGrid (Email)
# ============================================

SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=no-reply@puretask.com

# Email Template IDs (from SendGrid)
SENDGRID_TEMPLATE_CLIENT_JOB_BOOKED=
SENDGRID_TEMPLATE_CLIENT_JOB_ACCEPTED=
SENDGRID_TEMPLATE_CLIENT_CLEANER_ON_MY_WAY=
SENDGRID_TEMPLATE_CLIENT_JOB_COMPLETED=
SENDGRID_TEMPLATE_CLEANER_JOB_APPROVED=
SENDGRID_TEMPLATE_CLEANER_JOB_DISPUTED=
SENDGRID_TEMPLATE_USER_JOB_CANCELLED=
SENDGRID_TEMPLATE_CLIENT_CREDIT_PURCHASE=
SENDGRID_TEMPLATE_CLEANER_PAYOUT_SENT=
SENDGRID_TEMPLATE_USER_WELCOME=
SENDGRID_TEMPLATE_USER_EMAIL_VERIFICATION=
SENDGRID_TEMPLATE_USER_PASSWORD_RESET=

# ============================================
# ðŸ“± Notifications - Twilio (SMS)
# ============================================

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# SMS Template IDs
SMS_TEMPLATE_EMERGENCY=
SMS_TEMPLATE_JOB_REMINDER=

# ============================================
# ðŸ”” Notifications - OneSignal (Push)
# ============================================

ONESIGNAL_APP_ID=
ONESIGNAL_API_KEY=

# ============================================
# ðŸ”— Integrations
# ============================================

# n8n Workflow Integration
N8N_WEBHOOK_URL=
N8N_MCP_SERVER_URL=https://puretask.app.n8n.cloud/mcp-server/http
USE_EVENT_BASED_NOTIFICATIONS=true

# Application URLs
APP_URL=http://localhost:3000
STORAGE_URL=https://storage.puretask.com

# ============================================
# ðŸš¨ Alerting
# ============================================

ALERT_SLACK_WEBHOOK_URL=
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=alerts@puretask.com

# ============================================
# ðŸ¤– AI Features (Optional)
# ============================================

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ============================================
# ðŸ“… Google Calendar Integration (Optional)
# ============================================

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# ============================================
# ðŸ” OAuth Social Login (Optional)
# ============================================

# Facebook OAuth
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=

# ============================================
# âš™ï¸ Operational Settings (Optional)
# ============================================

GPS_CHECKIN_RADIUS_METERS=250
MIN_PHOTOS_TOTAL=3
MIN_BEFORE_PHOTOS=2
MIN_AFTER_PHOTOS=2
PHOTO_RETENTION_DAYS=90
DISPUTE_WINDOW_HOURS=48
CLEANER_NOSHOW_BONUS_CREDITS=50
NON_CREDIT_SURCHARGE_PERCENT=10
MIN_LEAD_TIME_HOURS=2
SUBSCRIPTION_DEFAULT_CREDITS=100
CANCELLATION_LOCK_HOURS=1
PAYOUT_CURRENCY=usd
