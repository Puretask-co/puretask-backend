# ============================================
# PureTask Backend - Environment Variables Template
# ============================================
# âš ï¸ NEVER commit actual secrets to version control!
# Copy this file to .env and fill in your actual values
# All secrets must be stored in Railway (production) or locally (development)

# ============================================
# REQUIRED - Core Configuration
# ============================================
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# ============================================
# REQUIRED - Database
# ============================================
DATABASE_URL=postgres://YOUR_USER:YOUR_PASSWORD@ep-YOUR-PROJECT.us-east-2.aws.neon.tech/puretask?sslmode=require

# ============================================
# REQUIRED - Authentication
# ============================================
JWT_SECRET=YOUR_JWT_SECRET_MIN_32_CHARS
JWT_EXPIRES_IN=30d
BCRYPT_SALT_ROUNDS=10

# ============================================
# REQUIRED - Stripe Payments
# ============================================
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_STRIPE_WEBHOOK_SECRET

# ============================================
# REQUIRED - Webhook Security
# ============================================
N8N_WEBHOOK_SECRET=YOUR_N8N_WEBHOOK_SECRET

# ============================================
# Optional - Feature Flags
# ============================================
BOOKINGS_ENABLED=true
PAYOUTS_ENABLED=false
CREDITS_ENABLED=true
REFUNDS_ENABLED=true
WORKERS_ENABLED=true

# ============================================
# Optional - Payout Configuration
# ============================================
PAYOUT_CURRENCY=usd
CENTS_PER_CREDIT=10
PLATFORM_FEE_PERCENT=15
CLEANER_PAYOUT_PERCENT_BRONZE=80
CLEANER_PAYOUT_PERCENT_SILVER=82
CLEANER_PAYOUT_PERCENT_GOLD=84
CLEANER_PAYOUT_PERCENT_PLATINUM=85
NON_CREDIT_SURCHARGE_PERCENT=10

# ============================================
# Optional - Operational Settings
# ============================================
GPS_CHECKIN_RADIUS_METERS=250
MIN_PHOTOS_TOTAL=3
MIN_BEFORE_PHOTOS=2
MIN_AFTER_PHOTOS=2
PHOTO_RETENTION_DAYS=90
DISPUTE_WINDOW_HOURS=48
CLEANER_NOSHOW_BONUS_CREDITS=50
MIN_LEAD_TIME_HOURS=2
SUBSCRIPTION_DEFAULT_CREDITS=100
CANCELLATION_LOCK_HOURS=1

# ============================================
# Optional - Integrations
# ============================================
N8N_WEBHOOK_URL=
N8N_MCP_SERVER_URL=
N8N_API_KEY=
APP_URL=http://localhost:3000
STORAGE_URL=https://storage.puretask.com
REDIS_URL=
USE_REDIS_RATE_LIMITING=false

# ============================================
# Optional - Email (SendGrid)
# ============================================
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=no-reply@puretask.com

# ============================================
# Optional - SMS (Twilio)
# ============================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ============================================
# Optional - Push Notifications (OneSignal)
# ============================================
ONESIGNAL_APP_ID=
ONESIGNAL_API_KEY=

# ============================================
# Optional - Alerting
# ============================================
ALERT_SLACK_WEBHOOK_URL=
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=alerts@puretask.com

# ============================================
# Optional - V2 Features
# ============================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=

# ============================================
# Optional - AI Features
# ============================================
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
